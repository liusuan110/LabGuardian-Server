# ---- Server ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ---- CORS ----
CORS_ORIGINS=["*"]

# ---- Redis / Celery (演示阶段不需要，使用同步 /pipeline/run 端点) ----
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---- YOLO 模型 ----
YOLO_MODEL_PATH=D:/desktop/LabGuardian-Server-main/LabGuardian-Server-main/models/unit_v1_yolov8s_960/weights/best.pt
YOLO_OBB_MODEL_PATH=D:/desktop/inter/LabGuardian/runs/pin_detect/pin_self_overfit/weights/best.pt
YOLO_CONF_THRESHOLD=0.25
YOLO_IOU_THRESHOLD=0.5
YOLO_IMGSZ=960
YOLO_DEVICE=0

# ---- 面包板 ----
BREADBOARD_ROWS=63
BREADBOARD_COLS_PER_SIDE=5
ROI_PADDING=30

# ---- Pipeline ----
PIPELINE_HIGH_RES_IMGSZ=640
PIN_CANDIDATE_K=5
REFERENCE_CIRCUIT_PATH=D:/desktop/LabGuardian-Server-main/LabGuardian-Server-main/reference_S01.json
